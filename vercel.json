{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server run build:vercel && pnpm --filter @workspace/invest-ke run build",
  "outputDirectory": "artifacts/invest-ke/dist/public",
  "functions": {
    "api/index.mjs": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "artifacts/api-server/dist/vercel.mjs"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.mjs" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
